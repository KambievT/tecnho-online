# ——————————————————————————————————————
# Production .env — TimeWeb Cloud
# Copy to .env and fill in real values
# ——————————————————————————————————————

# Database
DB_PASSWORD=CHANGE_ME_strong_password

# JWT secret (generate: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_random_secret

# Admin panel password
ADMIN_PASSWORD=CHANGE_ME_admin_password

# CORS — frontend public URL
CORS_ORIGIN=https://your-domain.ru

# Frontend — API URL (as seen by browser)
NEXT_PUBLIC_API_URL=https://your-domain.ru/api

# MinIO storage credentials
MINIO_ACCESS_KEY=CHANGE_ME_minio_access
MINIO_SECRET_KEY=CHANGE_ME_minio_secret

# Public URL for product images (via nginx /storage/ proxy)
MINIO_PUBLIC_URL=https://your-domain.ru/storage

# Swagger docs public URL
PUBLIC_API_URL=https://your-domain.ru
